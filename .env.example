# SOSFiler — Environment Variables
# Copy to .env and fill in your values

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (document AI enhancement)
OPENAI_API_KEY=sk-...

# Sensitive data / support automation
# Generate a long random value and keep it out of frontend builds.
PII_ENCRYPTION_KEY=
PII_FINGERPRINT_PEPPER=
SLACK_TICKETS_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_INTERACTIVE_TICKETS=false
SOSFILER_OPERATOR_COCKPIT_URL=https://sosfiler.com/operator.html

# Regulatory research (Firecrawl)
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_SECONDS=60
FIRECRAWL_MAX_POLL_SECONDS=600
FIRECRAWL_EXTRACT_MAX_URLS=10
REGULATORY_RESEARCH_AUTO_VERIFY=true
REGULATORY_LOCAL_SOURCE_LIMIT=8

# Supabase / Postgres system of record
# Use service-role/database credentials only on trusted backend workers.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require
# sqlite = local compatibility only; dual = SQLite primary plus Supabase writes; supabase = reserved for full cutover.
EXECUTION_PERSISTENCE_MODE=sqlite

# Optional regulatory research providers
TAVILY_API_KEY=
EXA_API_KEY=
APIFY_API_TOKEN=
ACCELA_CLIENT_ID=
ACCELA_CLIENT_SECRET=
ACCELA_BASE_URL=https://apis.accela.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
CAPTCHA_PROVIDER=anti-captcha
ANTICAPTCHA_API_KEY=

# SendGrid (email notifications)
EMAIL_DELIVERY_MODE=noop
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@sosfiler.com
SENDGRID_FROM_NAME=SOSFiler
SENDGRID_REPLY_TO=support@sosfiler.com
SENDGRID_TEST_RECIPIENT=admin@sosfiler.com
ADMIN_EMAIL=admin@sosfiler.com

# CorpNet partner API (Registered Agent integration scaffold)
CORPNET_API_BASE_URL=https://api.corpnet.com
CORPNET_API_KEY=
CORPNET_API_TIMEOUT_SECONDS=25
# Override endpoint paths as needed based on your partner docs:
CORPNET_RA_QUOTE_PATH=/v1/registered-agent/quotes
CORPNET_RA_ORDER_PATH=/v1/registered-agent/orders
CORPNET_RA_STATUS_PATH_TEMPLATE=/v1/registered-agent/orders/{external_order_id}

# App config
DASHBOARD_URL=https://sosfiler.com/dashboard.html
APP_ENV=production

# Optional: Replicate (if using for any AI features)
# REPLICATE_API_TOKEN=r8_...
