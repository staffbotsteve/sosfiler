    "articles_requirements": {
      "document_name": "Articles of Organization",
      "form_number": "LLC-1",
      "required_fields": ["llc_name", "purpose", "registered_agent_name", "registered_agent_address", "management_type", "organizer_name", "organizer_address"],
      "management_options": ["member-managed", "manager-managed"],
      "name_requirements": "Must contain 'LLC', 'L.L.C.', or 'Limited Liability Company'. Cannot contain 'bank', 'trust', 'trustee', 'incorporated', 'inc.', 'corporation', 'corp.'",
      "purpose_required": false,
      "purpose_default": "Any lawful purpose"
    },
    "registered_agent": {
      "required": true,
      "type": "individual_or_entity",
      "must_be_in_state": true,
      "form": "LLC-1 (included)"
    },
    "annual_report": {
      "required": true,
      "form": "LLC-12 (Statement of Information)",
      "frequency": "biennial",
      "due": "Within 90 days of filing, then every 2 years during filing month",
      "fee": 20,
      "late_penalty": 250
    },
    "franchise_tax": {
      "required": true,
      "amount": 800,
      "due": "15th day of 4th month after formation, then annually by April 15",
      "notes": "Minimum $800/year regardless of income. First-year exemption for LLCs formed 2021-2023."
    },
    "publication_required": false,
    "processing_time": "3-5 business days online",
    "expedited_available": true,
    "expedited_time": "24 hours",
    "online_filing": true
  },
