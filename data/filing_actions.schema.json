{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sosfiler.com/schemas/filing_actions.schema.json",
  "title": "SOSFiler Filing Actions",
  "type": "object",
  "description": "State/entity/action filing instructions used for pricing, customer intake, operator work, automation, evidence gates, and portal status.",
  "additionalProperties": {
    "type": "object",
    "description": "State abbreviation, e.g. TX.",
    "additionalProperties": {
      "type": "object",
      "description": "Entity type, e.g. LLC, C-Corp, S-Corp, Nonprofit, LP, LLP, PLLC.",
      "additionalProperties": {
        "$ref": "#/$defs/filingAction"
      }
    }
  },
  "$defs": {
    "filingAction": {
      "type": "object",
      "required": [
        "state",
        "entity_type",
        "action_type",
        "customer_product_name",
        "office",
        "filing_method",
        "state_fee_cents",
        "source_urls",
        "research_status",
        "last_verified"
      ],
      "properties": {
        "state": { "type": "string", "minLength": 2, "maxLength": 2 },
        "entity_type": { "type": "string" },
        "action_type": {
          "type": "string",
          "description": "Examples: formation, foreign_registration, foreign_amendment, foreign_withdrawal, amendment, annual_report, dissolution, reinstatement, registered_agent_change, address_change, governing_person_change, name_reservation, dba, fictitious_business_name, fbn_publication, city_business_license, county_business_license, local_business_tax_certificate, license_amendment, license_renewal, certificate_status, certified_copy, tax_registration, general_business_license, internal_member_change."
        },
        "customer_product_name": { "type": "string" },
        "jurisdiction_role": {
          "type": "string",
          "enum": ["domestic", "foreign", "statewide_business_authority", "local_business_authority", "internal_only", "unknown"],
          "description": "Whether this action creates or changes the domestic entity, qualifies a foreign entity, creates a general license/authority to do business, or is an internal-only SOSFiler service."
        },
        "jurisdiction_scope": {
          "type": "string",
          "enum": ["state", "county", "city", "city_and_county", "multi_jurisdiction", "internal", "unknown"]
        },
        "county": { "type": "string" },
        "city": { "type": "string" },
        "state_filed": { "type": "boolean", "default": true },
        "internal_documents_required": { "type": "boolean", "default": false },
        "office": { "type": "string" },
        "form_name": { "type": "string" },
        "form_number": { "type": "string" },
        "portal_name": { "type": "string" },
        "portal_url": { "type": "string" },
        "portal_account_required": { "type": "boolean" },
        "filing_method": {
          "type": "string",
          "enum": ["api", "web_portal", "upload_portal", "email", "mail", "in_person", "internal_only", "manual_review"]
        },
        "automation_level": {
          "type": "string",
          "enum": ["api_ready", "browser_automation_ready", "operator_assisted", "manual_review", "unsupported"]
        },
        "state_fee_cents": { "type": "integer", "minimum": 0 },
        "processing_fee": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["none", "fixed", "percent", "formula", "unknown"] },
            "amount_cents": { "type": "integer", "minimum": 0 },
            "rate": { "type": "number", "minimum": 0 },
            "applies_to": { "type": "string" },
            "label": { "type": "string" },
            "source_note": { "type": "string" }
          },
          "additionalProperties": true
        },
        "recommended_service_fee_cents": { "type": "integer", "minimum": 0 },
        "recommended_markup_strategy": {
          "type": "string",
          "enum": ["flat_fee", "percent_markup", "pass_through_plus_service_fee", "quote_required", "unavailable", "unknown"]
        },
        "price_confidence": {
          "type": "string",
          "enum": ["verified", "formula_verified", "range_only", "needs_operator_quote", "unknown"]
        },
        "variable_fee_formula": {
          "type": "string",
          "description": "Official formula when fees depend on revenue, employee count, business activity, location, square footage, publication vendor, or other variable inputs."
        },
        "fee_components": {
          "type": "object",
          "description": "Detailed fee components for local licensing/DBA/FBN and other filings.",
          "properties": {
            "initial_filing_fee_cents": { "type": "integer", "minimum": 0 },
            "formation_fee_cents": { "type": "integer", "minimum": 0 },
            "foreign_registration_fee_cents": { "type": "integer", "minimum": 0 },
            "foreign_amendment_fee_cents": { "type": "integer", "minimum": 0 },
            "foreign_withdrawal_fee_cents": { "type": "integer", "minimum": 0 },
            "name_reservation_fee_cents": { "type": "integer", "minimum": 0 },
            "amendment_fee_cents": { "type": "integer", "minimum": 0 },
            "registered_agent_change_fee_cents": { "type": "integer", "minimum": 0 },
            "address_change_fee_cents": { "type": "integer", "minimum": 0 },
            "governing_person_change_fee_cents": { "type": "integer", "minimum": 0 },
            "ownership_change_fee_cents": { "type": "integer", "minimum": 0 },
            "annual_report_fee_cents": { "type": "integer", "minimum": 0 },
            "reinstatement_fee_cents": { "type": "integer", "minimum": 0 },
            "dissolution_fee_cents": { "type": "integer", "minimum": 0 },
            "per_owner_fee_cents": { "type": "integer", "minimum": 0 },
            "per_name_fee_cents": { "type": "integer", "minimum": 0 },
            "copy_fee_cents": { "type": "integer", "minimum": 0 },
            "certified_copy_fee_cents": { "type": "integer", "minimum": 0 },
            "certificate_status_fee_cents": { "type": "integer", "minimum": 0 },
            "publication_estimate_cents": { "type": "integer", "minimum": 0 },
            "renewal_fee_cents": { "type": "integer", "minimum": 0 },
            "closure_fee_cents": { "type": "integer", "minimum": 0 },
            "late_fee_cents": { "type": "integer", "minimum": 0 },
            "price_notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "expedite_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "fee_cents": { "type": "integer", "minimum": 0 },
              "processing_time": { "type": "string" },
              "channel": { "type": "string" },
              "customer_selectable": { "type": "boolean" },
              "combinable": { "type": "boolean" },
              "source_url": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "prerequisite_filings": {
          "type": "array",
          "description": "Required or conditional filings/steps before this action can be submitted.",
          "items": {
            "type": "object",
            "properties": {
              "action_type": { "type": "string" },
              "label": { "type": "string" },
              "required": { "type": "boolean" },
              "condition": { "type": "string" },
              "fee_cents": { "type": "integer", "minimum": 0 },
              "validity_period": { "type": "string" },
              "evidence_required": { "type": "array", "items": { "type": "string" } },
              "customer_selectable": { "type": "boolean" },
              "source_url": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "process_steps": {
          "type": "array",
          "description": "Ordered filing path from intake through submission, payment, approval, and evidence capture.",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "integer", "minimum": 1 },
              "actor": { "type": "string", "enum": ["customer", "sosfiler", "state_portal", "third_party", "operator"] },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "portal_page": { "type": "string" },
              "required_inputs": { "type": "array", "items": { "type": "string" } },
              "evidence_output": { "type": "array", "items": { "type": "string" } },
              "status_after_step": { "type": "string" }
            },
            "required": ["step", "title"]
          }
        },
        "customer_options": {
          "type": "array",
          "description": "Options SOSFiler may expose to customers during checkout or post-order flows.",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "label": { "type": "string" },
              "option_type": { "type": "string", "enum": ["expedite", "copy", "certificate", "registered_agent", "publication", "name_reservation", "other"] },
              "government_fee_cents": { "type": "integer", "minimum": 0 },
              "service_fee_cents": { "type": "integer", "minimum": 0 },
              "required": { "type": "boolean" },
              "default_selected": { "type": "boolean" },
              "source_url": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "expected_processing_time": { "type": "string" },
        "required_customer_inputs": { "type": "array", "items": { "type": "string" } },
        "local_license_requirements": {
          "type": "object",
          "description": "For city/county licensing or FBN filings, records local operating-authority inputs and follow-on requirements.",
          "properties": {
            "publication_required": { "type": "boolean" },
            "publication_deadline_days": { "type": "integer", "minimum": 0 },
            "publication_fee_source": { "type": "string" },
            "zoning_clearance_required": { "type": "boolean" },
            "home_occupation_review_required": { "type": "boolean" },
            "estimated_receipts_required": { "type": "boolean" },
            "employee_count_required": { "type": "boolean" },
            "naics_required": { "type": "boolean" },
            "renewal_frequency": { "type": "string" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "home_jurisdiction_requirements": {
          "type": "object",
          "description": "For foreign registrations/qualifications, records home-state evidence needed before filing.",
          "properties": {
            "certificate_required": { "type": "boolean" },
            "certificate_type": { "type": "string" },
            "certificate_max_age_days": { "type": "integer", "minimum": 0 },
            "assumed_name_if_unavailable": { "type": "boolean" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "state_change_rules": {
          "type": "object",
          "description": "Clarifies whether a post-formation change is filed with the state or handled internally.",
          "properties": {
            "member_change_state_filed": { "type": "boolean" },
            "manager_change_state_filed": { "type": "boolean" },
            "officer_director_change_state_filed": { "type": "boolean" },
            "address_change_state_filed": { "type": "boolean" },
            "registered_agent_change_state_filed": { "type": "boolean" },
            "ownership_change_internal_only": { "type": "boolean" },
            "available_state_form": { "type": "string" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "required_consents": { "type": "array", "items": { "type": "string" } },
        "required_signatures": { "type": "array", "items": { "type": "string" } },
        "required_generated_documents": { "type": "array", "items": { "type": "string" } },
        "pre_submission_blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            },
            "required": ["code", "message"]
          }
        },
        "portal_field_sequence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "page": { "type": "string" },
              "fields": { "type": "array", "items": { "type": "string" } },
              "notes": { "type": "string" }
            },
            "required": ["page", "fields"]
          }
        },
        "required_evidence_for_ready_to_file": { "type": "array", "items": { "type": "string" } },
        "required_evidence_for_submitted": { "type": "array", "items": { "type": "string" } },
        "required_evidence_for_approved": { "type": "array", "items": { "type": "string" } },
        "required_evidence_for_rejected": { "type": "array", "items": { "type": "string" } },
        "approval_detection": { "type": "array", "items": { "type": "string" } },
        "customer_portal_outputs": { "type": "array", "items": { "type": "string" } },
        "operator_notes": { "type": "string" },
        "automation_blockers": { "type": "array", "items": { "type": "string" } },
        "source_urls": { "type": "array", "items": { "type": "string" } },
        "research_status": {
          "type": "string",
          "enum": ["verified_primary", "verified_form", "verified_portal_observed", "needs_confirmation", "unsupported"]
        },
        "last_verified": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
